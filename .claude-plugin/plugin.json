{
  "name": "taskpilot",
  "description": "Spawn and manage long-running autonomous Claude Code sessions for background tasks",
  "version": "0.6.0",
  "author": {
    "name": "Thatcher",
    "url": "https://github.com/ThatcherT"
  },
  "repository": "https://github.com/ThatcherT/taskpilot",
  "keywords": [
    "agent",
    "autonomous",
    "background",
    "task",
    "tmux",
    "channel",
    "scheduling",
    "cron"
  ],
  "built_in_capabilities": [
    "scheduling"
  ],
  "mcpServers": {
    "taskpilot": {
      "command": "python",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/server.py"
      ],
      "cwd": "${CLAUDE_PLUGIN_ROOT}"
    }
  }
}
